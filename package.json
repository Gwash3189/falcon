{
  "name": "falcon",
  "type": "module",
  "private": true,
  "scripts": {
    "setup": "[ -f .env ] || cp .env.example .env && pnpm install && pnpm pods:up && pnpm --filter @falcon/server migrate",
    "predev": "[ -f .env ] || cp .env.example .env",
    "dev": "pnpm pods:up && pnpm --filter @falcon/server dev",
    "pods:up": "podman compose up -d 2>/dev/null",
    "pods:down": "podman compose down",
    "dev:down": "pnpm run pods:down",
    "build": "pnpm -r --filter './packages/*' build",
    "test": "pnpm run pods:up && vitest",
    "test:unit": "vitest run unit",
    "test:integration": "pnpm run pods:up && vitest run integration && pnpm run pods:down",
    "coverage": "vitest run --coverage",
    "lint": "biome check .",
    "format": "biome format . --write",
    "typecheck": "pnpm -r exec tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@vitest/coverage-v8": "^3.2.4",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "uuidv7": "^1.1.0",
    "winston": "^3.19.0"
  }
}
